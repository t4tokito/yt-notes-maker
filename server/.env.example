# Get a key from https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# Any model id from https://openrouter.ai/models
# Cheap + reliable picks (verify the id is still listed on the models page):
#   deepseek/deepseek-v4-flash      (extremely cheap, fast)
#   google/gemini-3.1-flash-lite    (cheap, low latency)
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Port the server listens on
PORT=3000

# Optional but REQUIRED on cloud hosts (Render, etc.) where YouTube blocks the
# direct transcript fetch. Free 100 requests at https://supadata.ai
# Leave empty for local dev (direct fetch works from your home IP).
SUPADATA_API_KEY=
